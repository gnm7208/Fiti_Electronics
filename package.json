{
  "name": "fiti-electronics",
  "version": "1.0.0",
  "description": "A mini e-commerce web app for electronics",
  "main": "index.js",
  "scripts": {
    "start": "json-server --static . --port $PORT --host 0.0.0.0 db.json",
    "dev": "json-server --watch --static . db.json --port 3000 --host 0.0.0.0",
    "serve": "http-server -p 8080",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "dependencies": {
    "json-server": "^0.17.4"
  },
  "devDependencies": {
    "http-server": "^14.1.1",
    "vitest": "^3.2.0",
    "eslint": "^9.39.0",
    "@eslint/js": "^9.39.0",
    "globals": "^16.0.0"
  },
  "keywords": [
    "ecommerce",
    "electronics",
    "json-server"
  ],
  "author": "Mukirai George",
  "license": "MIT",
  "type": "module"
}