# Copy this file to .env and fill in real values. .env is git-ignored.

PORT=3000

# --- Safaricom Daraja (M-Pesa) sandbox --------------------------------------
# Create a free account + app at https://developer.safaricom.co.ke
# "Lipa Na M-Pesa Sandbox" gives you the shortcode + passkey below for free.
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
# Must be a publicly reachable HTTPS URL (e.g. your Render deployment) for
# Safaricom to POST the payment result back to. Not usable with localhost.
MPESA_CALLBACK_URL=https://your-app.onrender.com/api/payments/mpesa/callback

# --- Stripe (test mode) ------------------------------------------------------
# https://dashboard.stripe.com -> Developers -> API keys (toggle Test mode)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Admin dashboard (admin.html) --------------------------------------------
# Single hardcoded operator account - plaintext here is consistent with how
# the Daraja/Stripe secrets above are handled (a gitignored .env, not a
# credential database), compared with a constant-time check server-side.
# Pick a long random string for ADMIN_JWT_SECRET (e.g. `openssl rand -hex 32`).
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_JWT_SECRET=
